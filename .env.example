# EDA Studio 环境变量示例
# 复制为 .env 并填入真实值: cp .env.example .env && source .env

# ── OpenAI 兼容 provider ──────────────────────────
# 支持 OpenAI / DeepSeek / 智谱 等兼容端点
export OPENAI_API_KEY=""
export OPENAI_API_BASE=""
export OPENAI_MODEL=""

# ── Anthropic provider ────────────────────────────
# 使用 Claude 系列模型时填写;在 config.yaml 中设置 provider.type: anthropic
export ANTHROPIC_API_KEY=""
